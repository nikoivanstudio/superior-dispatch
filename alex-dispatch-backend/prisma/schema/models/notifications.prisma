model Notifications {
  id                         Int     @id @default(autoincrement())
  userId                     Int     @unique @map("user_id")
  user                       User    @relation(fields: [userId], references: [id])
  notificationsEmail         String? @map("notifications_email")
  deliveryConfirmationsEmail String? @map("delivery_confirmations_email")

  @@map("notifications")
}
