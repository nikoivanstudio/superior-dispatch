model Factoring {
  id             Int      @default(autoincrement())
  userId         Int      @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id])
  attachInvoices Boolean? @map("attach_invoices")
  deliveryDates  Boolean? @map("delivery_dates")
  invoiceEmail   String?  @map("invoice_email")
  companyName    String?  @map("company_name")
  address        String?
  city           String?
  state          String?
  phone          String?
  factoringFee   String?  @map("factoring_fee")

  @@map("factoring")
}
